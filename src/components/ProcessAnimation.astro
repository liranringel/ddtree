---
const stages = [
  {
    id: "draft",
    index: "01",
    label: "Draft Model",
    copy: "The block diffusion draft model runs one forward pass and outputs per-position distributions for the next block.",
  },
  {
    id: "build-tree",
    index: "02",
    label: "Build Tree",
    copy: "DDTree builds a draft tree from those distributions under the verifier node budget.",
  },
  {
    id: "verify-tree",
    index: "03",
    label: "Target Model",
    copy: "The target model runs one forward pass with tree attention and scores the entire tree.",
  },
  {
    id: "walk-tree",
    index: "04",
    label: "Walk Tree",
    copy: "Using the target model's decoding rule, DDTree walks matching children, commits the matched path, and carries the next bonus token forward.",
  },
] as const;

const guides = [
  { x: 286, label: "position 1" },
  { x: 394, label: "position 2" },
  { x: 504, label: "position 3" },
];

const nodes = [
  { id: "a", label: "a", x: 178, y: 174, type: "root" },
  { id: "b", label: "b", x: 286, y: 128, type: "draft", accepted: true },
  { id: "c", label: "c", x: 286, y: 220, type: "draft" },
  { id: "d", label: "d", x: 394, y: 96, type: "draft" },
  { id: "e", label: "e", x: 394, y: 174, type: "draft", accepted: true },
  { id: "f", label: "f", x: 394, y: 262, type: "draft" },
  { id: "g", label: "g", x: 504, y: 74, type: "draft" },
  { id: "h", label: "h", x: 504, y: 136, type: "draft" },
  { id: "i", label: "i", x: 504, y: 196, type: "draft" },
  { id: "ap", label: "a'", x: 562, y: 238, type: "bonus" },
] as const;

const edges = [
  { id: "edge-a-b", x1: 178, y1: 174, x2: 286, y2: 128 },
  { id: "edge-a-c", x1: 178, y1: 174, x2: 286, y2: 220 },
  { id: "edge-b-d", x1: 286, y1: 128, x2: 394, y2: 96 },
  { id: "edge-b-e", x1: 286, y1: 128, x2: 394, y2: 174 },
  { id: "edge-c-f", x1: 286, y1: 220, x2: 394, y2: 262 },
  { id: "edge-d-g", x1: 394, y1: 96, x2: 504, y2: 74 },
  { id: "edge-d-h", x1: 394, y1: 96, x2: 504, y2: 136 },
  { id: "edge-e-i", x1: 394, y1: 174, x2: 504, y2: 196 },
];
---

<div class="process-player" data-process-player data-stage={stages[0].id}>
  <div class="process-player__frame">
    <svg
      class="process-player__svg"
      viewBox="0 0 620 330"
      role="img"
      aria-labelledby="ddtree-process-title ddtree-process-desc"
    >
      <title id="ddtree-process-title">One DDTree decoding round</title>
      <desc id="ddtree-process-desc">
        The previous bonus token enters as the root, a draft tree is selected, the target model scores
        the whole tree in one forward pass with tree attention, the walk follows matching children, and the
        next unmatched token becomes the next bonus token.
      </desc>

      <defs>
        <linearGradient id="process-bg" x1="0%" y1="0%" x2="100%" y2="100%">
          <stop offset="0%" stop-color="rgba(255,255,255,0.92)"></stop>
          <stop offset="100%" stop-color="rgba(255,255,255,0.7)"></stop>
        </linearGradient>
        <marker id="process-arrow-green" viewBox="0 0 12 12" refX="10" refY="6" markerWidth="7" markerHeight="7" orient="auto">
          <path d="M0 0 12 6 0 12Z" fill="#2d8b57"></path>
        </marker>
        <marker id="process-arrow-orange" viewBox="0 0 12 12" refX="10" refY="6" markerWidth="7" markerHeight="7" orient="auto">
          <path d="M0 0 12 6 0 12Z" fill="#c98739"></path>
        </marker>
      </defs>

      <rect class="process-player__surface" x="1" y="1" width="618" height="328" rx="28"></rect>

      <g class="process-player__guides">
        {guides.map((guide) => (
          <g class="process-player__guide" key={guide.label}>
            <line x1={guide.x} y1="34" x2={guide.x} y2="286"></line>
            <text x={guide.x} y="24">{guide.label}</text>
          </g>
        ))}
      </g>

      <rect class="process-player__verify-focus" x="144" y="46" width="402" height="246" rx="22"></rect>
      <text class="process-player__verify-caption" x="345" y="66">one verifier forward pass</text>

      <g class="process-player__context-group">
        <rect class="process-player__context-box" x="38" y="152" width="94" height="42" rx="12"></rect>
        <text class="process-player__context-label" x="85" y="178">context</text>
        <line class="process-player__context-arrow" x1="132" y1="173" x2="154" y2="173"></line>
      </g>

      <g class="process-player__draft-pass">
        <g class="process-player__draft-input">
          <rect class="process-player__draft-slot" x="265" y="232" width="42" height="34" rx="10"></rect>
          <rect class="process-player__draft-slot" x="373" y="232" width="42" height="34" rx="10"></rect>
          <rect class="process-player__draft-slot" x="483" y="232" width="42" height="34" rx="10"></rect>
          <text class="process-player__draft-slot-mask" x="286" y="254">m</text>
          <text class="process-player__draft-slot-mask" x="394" y="254">m</text>
          <text class="process-player__draft-slot-mask" x="504" y="254">m</text>
          <rect class="process-player__draft-caption-chip" x="251" y="272" width="286" height="22" rx="11"></rect>
          <text class="process-player__draft-caption" x="394" y="287">mask tokens</text>
        </g>

        <g class="process-player__draft-column" transform="translate(246 50)">
          <rect class="process-player__draft-card" width="80" height="154" rx="16"></rect>
          <text class="process-player__draft-card-label" x="40" y="22">pos 1</text>
          <rect class="process-player__draft-bar" x="16" y="34" width="48" height="24" rx="8"></rect>
          <text class="process-player__draft-token" x="40" y="51">b</text>
          <rect class="process-player__draft-bar process-player__draft-bar--mid" x="16" y="66" width="34" height="18" rx="7"></rect>
          <text class="process-player__draft-token process-player__draft-token--small" x="33" y="79">c</text>
          <rect class="process-player__draft-bar process-player__draft-bar--low" x="16" y="92" width="22" height="14" rx="6"></rect>
          <text class="process-player__draft-token process-player__draft-token--tiny" x="27" y="103">...</text>
        </g>

        <g class="process-player__draft-column" transform="translate(354 50)">
          <rect class="process-player__draft-card" width="80" height="154" rx="16"></rect>
          <text class="process-player__draft-card-label" x="40" y="22">pos 2</text>
          <rect class="process-player__draft-bar" x="16" y="34" width="48" height="24" rx="8"></rect>
          <text class="process-player__draft-token" x="40" y="51">d</text>
          <rect class="process-player__draft-bar process-player__draft-bar--mid" x="16" y="66" width="40" height="18" rx="7"></rect>
          <text class="process-player__draft-token process-player__draft-token--small" x="36" y="79">e</text>
          <rect class="process-player__draft-bar process-player__draft-bar--low" x="16" y="92" width="30" height="16" rx="6"></rect>
          <text class="process-player__draft-token process-player__draft-token--small" x="31" y="105">f</text>
          <rect class="process-player__draft-bar process-player__draft-bar--low" x="16" y="116" width="20" height="12" rx="6"></rect>
          <text class="process-player__draft-token process-player__draft-token--tiny" x="26" y="126">...</text>
        </g>

        <g class="process-player__draft-column" transform="translate(464 50)">
          <rect class="process-player__draft-card" width="80" height="154" rx="16"></rect>
          <text class="process-player__draft-card-label" x="40" y="22">pos 3</text>
          <rect class="process-player__draft-bar" x="16" y="34" width="44" height="22" rx="8"></rect>
          <text class="process-player__draft-token" x="38" y="50">g</text>
          <rect class="process-player__draft-bar process-player__draft-bar--mid" x="16" y="64" width="38" height="18" rx="7"></rect>
          <text class="process-player__draft-token process-player__draft-token--small" x="35" y="77">h</text>
          <rect class="process-player__draft-bar process-player__draft-bar--low" x="16" y="90" width="30" height="16" rx="6"></rect>
          <text class="process-player__draft-token process-player__draft-token--small" x="31" y="103">i</text>
          <rect class="process-player__draft-bar process-player__draft-bar--low" x="16" y="114" width="20" height="12" rx="6"></rect>
          <text class="process-player__draft-token process-player__draft-token--tiny" x="26" y="124">...</text>
        </g>
      </g>

      <g class="process-player__edge-layer">
        {edges.map((edge) => (
          <line
            class="process-player__edge"
            id={edge.id}
            key={edge.id}
            x1={edge.x1}
            y1={edge.y1}
            x2={edge.x2}
            y2={edge.y2}
          ></line>
        ))}
      </g>

      <g class="process-player__accept-layer">
        <line
          class="process-player__accept-edge process-player__accept-edge--first"
          x1="198.2"
          y1="165.4"
          x2="267.6"
          y2="135.8"
          marker-end="url(#process-arrow-green)"
        ></line>
        <line
          class="process-player__accept-edge process-player__accept-edge--second"
          x1="304.4"
          y1="135.8"
          x2="375.6"
          y2="166.2"
          marker-end="url(#process-arrow-green)"
        ></line>
        <line
          class="process-player__bonus-edge"
          x1="412.7"
          y1="181.1"
          x2="541.5"
          y2="230.2"
          marker-end="url(#process-arrow-orange)"
        ></line>
        <circle class="process-player__walker" cx="178" cy="174" r="7"></circle>
      </g>

      <g class="process-player__node-layer">
        {nodes.map((node) => (
          <g
            class:list={[
              "process-player__node",
              node.type === "draft" && "process-player__node--draft",
              node.type === "root" && "process-player__node--root",
              node.type === "bonus" && "process-player__node--bonus",
              node.accepted && "process-player__node--accepted",
            ]}
            data-node-id={node.id}
            key={node.id}
            transform={`translate(${node.x} ${node.y})`}
          >
            <circle r={node.type === "root" || node.type === "bonus" ? "22" : "20"}></circle>
            <text y="6">{node.label}</text>
          </g>
        ))}
      </g>

      <text class="process-player__note process-player__note--root" x="178" y="214">previous bonus</text>
      <text class="process-player__note process-player__note--bonus" x="562" y="274">next bonus</text>
    </svg>
  </div>

  <div class="process-player__controls" aria-label="DDTree process stages">
    {stages.map((stage, index) => (
      <button
        class="process-player__step"
        type="button"
        data-stage-button
        data-stage-id={stage.id}
        data-stage-copy={stage.copy}
        data-stage-index={index}
        aria-pressed={index === 0 ? "true" : "false"}
      >
        <span class="process-player__step-index">{stage.index}</span>
        <span class="process-player__step-label">{stage.label}</span>
      </button>
    ))}
  </div>

  <p class="process-player__copy" data-stage-live-copy aria-live="polite">{stages[0].copy}</p>
</div>

<script is:inline>
  const processPlayers = document.querySelectorAll("[data-process-player]");

  for (const player of processPlayers) {
    const buttons = Array.from(player.querySelectorAll("[data-stage-button]"));
    const copy = player.querySelector("[data-stage-live-copy]");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    const hoverCapable = window.matchMedia("(hover: hover) and (pointer: fine)");
    const stageDurations = {
      draft: 3000,
      "build-tree": 3000,
      "verify-tree": 3000,
      "walk-tree": 4200,
    };
    const resumeDelay = 4200;

    let activeIndex = 0;
    let isAutoplaying = !reduceMotion.matches;
    let isHoverLocked = false;
    let interactionPauseUntil = 0;
    let advanceTimer = 0;
    let resumeTimer = 0;

    const applyStage = (index) => {
      activeIndex = index;
      const activeButton = buttons[index];
      player.dataset.stage = activeButton.dataset.stageId;
      if (copy) copy.textContent = activeButton.dataset.stageCopy ?? "";

      buttons.forEach((button, buttonIndex) => {
        const isActive = buttonIndex === index;
        button.setAttribute("aria-pressed", String(isActive));
        button.dataset.active = String(isActive);
      });
    };

    const stopAdvance = () => {
      window.clearTimeout(advanceTimer);
      advanceTimer = 0;
    };

    const stopResume = () => {
      window.clearTimeout(resumeTimer);
      resumeTimer = 0;
    };

    const scheduleAdvance = () => {
      stopAdvance();
      if (!isAutoplaying || isHoverLocked || reduceMotion.matches) return;
      const activeStageId = buttons[activeIndex]?.dataset.stageId ?? "draft";
      const waitDuration = stageDurations[activeStageId] ?? 1900;
      advanceTimer = window.setTimeout(() => {
        applyStage((activeIndex + 1) % buttons.length);
        scheduleAdvance();
      }, waitDuration);
    };

    const scheduleResume = () => {
      stopResume();
      if (isHoverLocked || reduceMotion.matches) return;
      const wait = Math.max(0, interactionPauseUntil - Date.now());
      resumeTimer = window.setTimeout(() => {
        if (isHoverLocked) return;
        isAutoplaying = true;
        scheduleAdvance();
      }, wait);
    };

    const setInteractiveStage = (index) => {
      isAutoplaying = false;
      interactionPauseUntil = Date.now() + resumeDelay;
      stopAdvance();
      applyStage(index);
      scheduleResume();
    };

    buttons.forEach((button, index) => {
      button.addEventListener("click", () => {
        setInteractiveStage(index);
      });

      button.addEventListener("focus", () => {
        setInteractiveStage(index);
      });

      if (hoverCapable.matches) {
        button.addEventListener("pointerenter", () => {
          isHoverLocked = true;
          isAutoplaying = false;
          stopAdvance();
          stopResume();
          applyStage(index);
        });
      }
    });

    if (hoverCapable.matches) {
      player.querySelector(".process-player__controls")?.addEventListener("pointerleave", () => {
        isHoverLocked = false;
        interactionPauseUntil = Date.now() + resumeDelay;
        scheduleResume();
      });
    }

    player.querySelector(".process-player__controls")?.addEventListener("keydown", (event) => {
      const currentButton = document.activeElement;
      const currentIndex = buttons.indexOf(currentButton);
      if (currentIndex === -1) return;

      let nextIndex = currentIndex;
      if (event.key === "ArrowRight") nextIndex = (currentIndex + 1) % buttons.length;
      if (event.key === "ArrowLeft") nextIndex = (currentIndex - 1 + buttons.length) % buttons.length;
      if (event.key === "Home") nextIndex = 0;
      if (event.key === "End") nextIndex = buttons.length - 1;
      if (nextIndex === currentIndex) return;

      event.preventDefault();
      buttons[nextIndex].focus();
      setInteractiveStage(nextIndex);
    });

    const handleMotionPreference = () => {
      if (reduceMotion.matches) {
        isAutoplaying = false;
        stopAdvance();
        stopResume();
      } else if (!isHoverLocked && !resumeTimer && !advanceTimer) {
        isAutoplaying = true;
        scheduleAdvance();
      }
    };

    if (typeof reduceMotion.addEventListener === "function") {
      reduceMotion.addEventListener("change", handleMotionPreference);
    } else if (typeof reduceMotion.addListener === "function") {
      reduceMotion.addListener(handleMotionPreference);
    }

    applyStage(activeIndex);
    scheduleAdvance();
  }
</script>

<style>
  .process-player {
    display: grid;
    gap: 1rem;
    max-width: 52rem;
  }

  .process-player__frame {
    border: 1px solid rgba(24, 35, 55, 0.08);
    border-radius: 1.65rem;
    background:
      radial-gradient(circle at 20% 18%, rgba(183, 100, 62, 0.12), transparent 20%),
      radial-gradient(circle at 80% 76%, rgba(47, 84, 111, 0.12), transparent 24%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0.58));
    box-shadow: 0 22px 48px rgba(24, 35, 55, 0.06);
    overflow: hidden;
  }

  .process-player__svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .process-player__surface {
    fill: rgba(255, 255, 255, 0.58);
    stroke: rgba(24, 35, 55, 0.06);
  }

  .process-player__guide line,
  .process-player__guide text,
  .process-player__verify-focus,
  .process-player__verify-caption,
  .process-player__draft-pass,
  .process-player__draft-card,
  .process-player__draft-bar,
  .process-player__draft-token,
  .process-player__draft-slot,
  .process-player__draft-slot-label,
  .process-player__draft-slot-mask,
  .process-player__draft-caption-chip,
  .process-player__draft-caption,
  .process-player__edge,
  .process-player__node circle,
  .process-player__node text,
  .process-player__note,
  .process-player__accept-edge,
  .process-player__bonus-edge,
  .process-player__context-box,
  .process-player__context-label,
  .process-player__context-arrow {
    transition:
      opacity 260ms ease,
      transform 260ms ease,
      stroke 260ms ease,
      stroke-width 260ms ease,
      fill 260ms ease,
      filter 260ms ease;
  }

  .process-player__draft-card {
    fill: rgba(255, 255, 255, 0.9);
    stroke: rgba(0, 0, 0, 0.12);
    stroke-width: 1.1;
  }

  .process-player__draft-card-label {
    fill: rgba(36, 36, 36, 0.56);
    font-size: 11px;
    font-weight: 600;
    text-anchor: middle;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .process-player__draft-bar {
    fill: rgba(112, 112, 112, 0.24);
  }

  .process-player__draft-bar--mid {
    fill: rgba(112, 112, 112, 0.18);
  }

  .process-player__draft-bar--low {
    fill: rgba(112, 112, 112, 0.12);
  }

  .process-player__draft-token {
    fill: rgba(12, 31, 197, 0.9);
    font-size: 18px;
    font-weight: 600;
    text-anchor: middle;
  }

  .process-player__draft-token--small {
    font-size: 14px;
    font-weight: 500;
  }

  .process-player__draft-token--tiny {
    fill: rgba(12, 31, 197, 0.58);
    font-size: 11px;
    font-weight: 600;
  }

  .process-player__draft-slot {
    fill: rgba(0, 0, 0, 0.03);
    stroke: rgba(0, 0, 0, 0.18);
    stroke-width: 1;
  }

  .process-player__draft-slot--bonus {
    fill: rgba(52, 90, 173, 0.12);
    stroke: rgba(12, 31, 197, 0.72);
  }

  .process-player__draft-slot-label {
    fill: rgba(12, 31, 197, 0.92);
    font-size: 18px;
    font-weight: 600;
    text-anchor: middle;
  }

  .process-player__draft-slot-mask {
    fill: rgba(24, 24, 24, 0.5);
    font-size: 15px;
    font-weight: 600;
    text-anchor: middle;
  }

  .process-player__draft-caption {
    fill: rgba(36, 36, 36, 0.64);
    font-size: 12px;
    font-weight: 600;
    text-anchor: middle;
  }

  .process-player__draft-caption-chip {
    fill: rgba(255, 255, 255, 0.92);
    stroke: rgba(24, 35, 55, 0.08);
    stroke-width: 1;
  }

  .process-player__guide line {
    stroke: rgba(24, 24, 24, 0.1);
    stroke-width: 1;
  }

  .process-player__guide text {
    fill: rgba(36, 36, 36, 0.58);
    font-size: 12px;
    text-anchor: middle;
  }

  .process-player__verify-focus {
    fill: rgba(52, 90, 173, 0.035);
    stroke: rgba(52, 90, 173, 0.18);
    stroke-width: 1.5;
    stroke-dasharray: 6 8;
    opacity: 0;
  }

  .process-player__verify-caption {
    fill: rgba(52, 90, 173, 0.72);
    font-size: 12px;
    font-weight: 600;
    text-anchor: middle;
    opacity: 0;
  }

  .process-player__context-box {
    fill: rgba(0, 0, 0, 0.035);
    stroke: rgba(0, 0, 0, 0.22);
    stroke-width: 1.4;
  }

  .process-player__context-label {
    fill: rgba(24, 24, 24, 0.92);
    font-size: 16px;
    font-weight: 500;
    text-anchor: middle;
  }

  .process-player__context-arrow {
    stroke: rgba(0, 0, 0, 0.44);
    stroke-width: 1.6;
  }

  .process-player__edge {
    stroke: rgba(0, 0, 0, 0.34);
    stroke-width: 1.55;
    stroke-linecap: round;
  }

  .process-player__accept-edge {
    fill: none;
    stroke: #0b8d1f;
    stroke-width: 4.1;
    stroke-linecap: round;
    stroke-linejoin: round;
    opacity: 0;
    stroke-dasharray: 180;
    stroke-dashoffset: 180;
  }

  .process-player__accept-edge--second {
    stroke-dasharray: 160;
    stroke-dashoffset: 160;
  }

  .process-player__bonus-edge {
    fill: none;
    stroke: #e17b08;
    stroke-width: 2.9;
    stroke-linecap: round;
    stroke-dasharray: 9 8;
    opacity: 0;
  }

  .process-player__walker {
    fill: #0b8d1f;
    stroke: rgba(255, 255, 255, 0.96);
    stroke-width: 2;
    opacity: 0;
    filter: drop-shadow(0 6px 10px rgba(11, 141, 31, 0.2));
    transform-box: fill-box;
    transform-origin: center;
  }

  .process-player__node circle {
    stroke-width: 1.8;
  }

  .process-player__node text {
    fill: rgba(24, 24, 24, 0.95);
    font-size: 20px;
    font-weight: 500;
    text-anchor: middle;
  }

  .process-player__node--root circle {
    fill: rgba(52, 90, 173, 0.12);
    stroke: rgba(12, 31, 197, 0.9);
  }

  .process-player__node--bonus circle {
    fill: rgba(225, 123, 8, 0.14);
    stroke: rgba(225, 123, 8, 0.9);
  }

  .process-player__node--bonus {
    opacity: 0;
  }

  .process-player__node--draft circle {
    fill: rgba(0, 0, 0, 0.03);
    stroke: rgba(0, 0, 0, 0.45);
  }

  .process-player__node--accepted circle {
    fill: rgba(0, 0, 0, 0.03);
    stroke: rgba(0, 0, 0, 0.45);
  }

  .process-player__note {
    fill: rgba(36, 36, 36, 0.72);
    font-size: 13px;
    font-weight: 600;
    text-anchor: middle;
  }

  .process-player__note--root {
    fill: rgba(12, 31, 197, 0.9);
  }

  .process-player__note--bonus {
    fill: rgba(225, 123, 8, 0.95);
    opacity: 0;
  }

  .process-player__controls {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .process-player__step {
    display: grid;
